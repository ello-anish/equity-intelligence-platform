# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
#
# `.env` is gitignored; this template file is NOT.

# ── PostgreSQL (used by airflow + pipeline) ─────────────────────────
POSTGRES_DB=equity_db
POSTGRES_USER=equity_user
# Pick any strong password — only used by your local docker container.
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── Airflow secrets ─────────────────────────────────────────────────
# Regenerate a new Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=generate_a_new_fernet_key_and_paste_it_here

# Webserver secret key — any random string (≥32 chars recommended).
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_SECRET_KEY=generate_a_new_secret_key_and_paste_it_here

# ── Optional: MLflow tracking URI ───────────────────────────────────
# Defaults to local file store (./mlruns) if unset.
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── Optional: News API key for real (non-synthetic) sentiment ───────
# If set, the sentiment layer will prefer real headlines over the
# synthetic fallback stream. See quant/ml/sentiment.py.
# NEWSAPI_KEY=
